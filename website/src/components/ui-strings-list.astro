---
import { Code } from '@astrojs/starlight/components';
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { dirname, join } from 'node:path';

// Resolve @astrojs/starlight package path and read translations file
const require = createRequire(import.meta.url);
const starlightPath = require.resolve('@astrojs/starlight');
const starlightDir = dirname(starlightPath);
const translationsPath = join(starlightDir, 'translations', 'en.json');
const uiStrings = readFileSync(translationsPath, 'utf-8');
---

<Code code={uiStrings} lang="json" />
